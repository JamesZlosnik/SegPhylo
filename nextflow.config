// ============================================================
// nextflow.config — segmented virus phylogenetics pipeline
// ============================================================

// Default parameters (override via CLI: --param value)
params {
    l_fasta      = null
    m_fasta      = null
    s_fasta      = null
    root_l       = null
    root_m       = null
    root_s       = null
    outdir       = "results"
    mafft_args   = "--auto"
    iqtree_model    = "GTR+G"
    iqtree_boot     = 1000
    label_taxa_max  = 250    // suppress sample labels in barcode plot above this count
    min_len_l       = 6000   // minimum length for segment L
    min_len_m       = 3000   // minimum length for segment M
    min_len_s       = 1000   // minimum length for segment S
    dropped_strains = null   // optional file of sample names to exclude (one per line)
    mask_from_start  = 30     // positions to mask from start of each aligned segment
    mask_from_end    = 50     // positions to mask from end of each aligned segment
    remove_reference = false  // remove OUTGROUP from alignment before tree building
    root             = "outgroup" // tree rooting: "outgroup" or "midpoint"
    segment_trees_all_passing = false // per-segment trees use all samples passing
                                      // that segment's length threshold
}

// Default per-process resources
process {
    cpus   = 4
    memory = '8 GB'
    time   = '2h'

    withName: 'MAFFT_ALIGN' {
        cpus   = 8
        memory = '8 GB'
        time   = '2h'
    }
    withName: 'IQTREE_SEGMENT' {
        cpus   = 8
        memory = '16 GB'
        time   = '6h'
    }
    withName: 'IQTREE_CONCATENATED' {
        cpus   = 8
        memory = '24 GB'
        time   = '12h'
    }
}

// ============================================================
// Profiles
// ============================================================

profiles {

    // Run everything locally (default)
    local {
        process.executor = 'local'
        process.maxForks = 4
    }

    // SLURM cluster — adjust clusterOptions for your site
    slurm {
        process.executor    = 'slurm'
        // process.clusterOptions = '--account=myaccount --partition=compute'
    }

    // Conda environment — channels defined in environment.yml (no defaults)
    conda {
        conda.enabled   = true
        process.conda   = "${projectDir}/environment.yml"
    }

    // Singularity container
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
    }
}

// ============================================================
// Execution reports
// ============================================================

report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_timeline.html"
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_trace.txt"
}
